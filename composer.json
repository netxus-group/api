{
    "name": "netxus/api",
    "description": "Netxus Portal News - API Backend (CodeIgniter 4)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.5, <4.7",
        "firebase/php-jwt": "^7.0",
        "phpoffice/phpspreadsheet": "^2.0",
        "maennchen/zipstream-php": "^2.4",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "scripts": {
        "post-update-cmd": [
            "@php spark migrate --all"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
