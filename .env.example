#--------------------------------------------------------------------
# NETXUS API - ENVIRONMENT CONFIGURATION
#--------------------------------------------------------------------
# Renombrar este archivo a .env y ajustar los valores.
# NUNCA subir .env al repositorio.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = production
# CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
# Docker: http://localhost:8080/  |  Hosting: https://tu-dominio.com/
app.baseURL = 'http://localhost:8080/'
# app.forceGlobalSecureRequests = true

app.appTimezone = 'America/Argentina/Buenos_Aires'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
# Docker: hostname = mysql  |  Local: hostname = localhost / 127.0.0.1
database.default.hostname = localhost
database.default.database = netxus_db
database.default.username = netxus
database.default.password = netxus_pwd
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

#--------------------------------------------------------------------
# JWT / AUTH
#--------------------------------------------------------------------
JWT_SECRET = 'change-this-to-a-long-random-string-min-32-chars'
JWT_REFRESH_SECRET = 'another-long-random-string-different-from-above'
JWT_ACCESS_EXPIRES = 900
JWT_REFRESH_EXPIRES = 604800

# Portal users auth (separated from editorial auth)
PORTAL_JWT_SECRET = 'portal-jwt-secret-change-this-too'
PORTAL_JWT_REFRESH_SECRET = 'portal-refresh-secret-change-this-too'
PORTAL_JWT_ACCESS_EXPIRES = 900
PORTAL_JWT_REFRESH_EXPIRES = 1209600
PORTAL_PASSWORD_RESET_EXPIRES = 3600
PORTAL_BCRYPT_COST = 10
PORTAL_MAX_LOGIN_ATTEMPTS = 8
PORTAL_LOGIN_ATTEMPT_WINDOW = 300

# Public API shared-secret token
PUBLIC_API_SECRET = '2ab1cd32caacb3e12b7f021a83aa8fad27251069'

#--------------------------------------------------------------------
# CORS
#--------------------------------------------------------------------
CORS_ALLOWED_ORIGINS = 'http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:5174'

#--------------------------------------------------------------------
# UPLOADS
#--------------------------------------------------------------------
UPLOADS_PATH = 'writable/uploads/'
UPLOADS_PUBLIC_URL = '/uploads/'
UPLOADS_MAX_SIZE = 8192

#--------------------------------------------------------------------
# NEWSLETTER
#--------------------------------------------------------------------
NEWSLETTER_UNSUBSCRIBE_SECRET = 'newsletter-secret-change-me'
PUBLIC_SITE_URL = 'http://localhost:5173'

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------
# email.protocol = smtp
# email.SMTPHost = smtp.example.com
# email.SMTPUser = user@example.com
# email.SMTPPass = secret
# email.SMTPPort = 587
# email.SMTPCrypto = tls
# email.mailType = html

#--------------------------------------------------------------------
# INTEGRATIONS
#--------------------------------------------------------------------
# Weather API (open-meteo)
WEATHER_API_URL = 'https://api.open-meteo.com/v1/forecast'
WEATHER_LATITUDE = -34.6037
WEATHER_LONGITUDE = -58.3816

# Currency/Dollar API
CURRENCY_API_URL = 'https://open.er-api.com/v6/latest/USD'

#--------------------------------------------------------------------
# LOGGING
#--------------------------------------------------------------------
